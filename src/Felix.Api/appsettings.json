{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Redis": "localhost:4080"
  },
  "Conversation": {
    "MaxMessages": 30,
    "TtlDays": 1
  },
  "CwaApiKey": "",
  "AiModel": {
    "Gemini": {
      "Model": "gemini-2.5-flash",
      "ApiKey": ""
    },
    "Groq": {
      "Model": "llama-3.1-8b-instant",
      "ApiKey": ""
    },
    "Mistral": {
      "Model": "open-mistral-nemo",
      "ApiKey": ""
    }
  },
  "Mcp": {
    "Servers": [
      {
        "Name": "weather",
        "Command": "npx",
        "Arguments": ["-y", "@dangahagan/weather-mcp@latest"],
        "Enabled": true
      },
      {
        "Name": "geocoding",
        "Command": "npx",
        "Arguments": ["-y", "@geocoding-ai/mcp"],
        "Enabled": true
      }
    ]
  }
}
